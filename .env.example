# Optional after a human-approved Sepolia deployment.
OPPORTUNITY_REGISTRY_ADDRESS=

# Public Sepolia address for the deployed Nox ConfidentialStrategyVault.
NEXT_PUBLIC_NOX_STRATEGY_VAULT_ADDRESS=

# Optional browser-readable Sepolia RPC override. Never put a private key here.
NEXT_PUBLIC_SEPOLIA_RPC_URL=

# Server-only KeeperHub organization key. Never expose it as NEXT_PUBLIC_*.
KEEPERHUB_API_KEY=

# Explicit human gate for non-broadcast simulation requests. Keep false by default.
KEEPERHUB_SIMULATION_ENABLED=false
